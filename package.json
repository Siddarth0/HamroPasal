{
  "name": "ecommerce",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:api": "turbo run dev --filter=api",
    "dev:web": "turbo run dev --filter=web",
    "dev:seller": "turbo run dev --filter=seller",
    "dev:admin": "turbo run dev --filter=admin"
  },
  "devDependencies": {
    "turbo": "^2.9.16",
    "typescript": "^5.9.2"
  },
  "comment": "react/react-dom pinned so the web (Next 14) build resolves a single React 18; @scalar's React 19 nests under the API only.",
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0" 
  }
}
