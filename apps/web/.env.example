# Base URL of the HamroPasal API (include the /api prefix).
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Seller Center app (where "Sell on HamroPasal" links point).
NEXT_PUBLIC_SELLER_URL=http://localhost:3001

# Canonical public origin of this storefront (no trailing slash).
# Drives canonical URLs, sitemap.xml, robots.txt, Open Graph + JSON-LD.
NEXT_PUBLIC_SITE_URL=https://hamropasal-alpha.vercel.app
