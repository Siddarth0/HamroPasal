MONGO_URI="mongodb://localhost:27017"

# Pooled connection — used by the app at runtime (Neon: host has "-pooler")
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"
# Direct connection — used by Prisma CLI for migrations (Neon: host WITHOUT "-pooler")
DIRECT_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"

NODE_ENV="development"

# ── eSewa ePay v2 (sandbox/test) ─────────────────────
# Sandbox merchant: product code EPAYTEST + the public test secret below.
# Test login on eSewa: ID 9711111111, password Nepal@123, MPIN 1122, OTP 123456.
# ESEWA_BASE_URL/SECRET_KEY default to sandbox in config; set MERCHANT_CODE to enable.
ESEWA_MERCHANT_CODE="EPAYTEST"
ESEWA_SECRET_KEY="8gBm/:&EnhH.1/q"
ESEWA_BASE_URL="https://rc-epay.esewa.com.np"
ESEWA_SUCCESS_URL="http://localhost:3000/payment/success"
ESEWA_FAILURE_URL="http://localhost:3000/payment/failure"

# ── Email (Gmail SMTP via nodemailer) ────────────────
# Use a Google App Password (Account → Security → 2-Step Verification → App
# passwords). SMTP_PASS is the 16-char password; EMAIL_FROM must match SMTP_USER.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="you@gmail.com"
SMTP_PASS="your_16_char_app_password"
EMAIL_FROM="you@gmail.com"
