MONGO_URI="mongodb://localhost:27017"

# Pooled connection — used by the app at runtime (Neon: host has "-pooler")
DATABASE_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"
# Direct connection — used by Prisma CLI for migrations (Neon: host WITHOUT "-pooler")
DIRECT_URL="postgresql://user:password@localhost:5432/ecommerce?schema=public"

NODE_ENV="development"

